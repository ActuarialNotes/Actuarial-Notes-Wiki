VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GITHUB_REPO=ActuarialNotes/Actuarial-Notes-Wiki
VITE_GITHUB_BRANCH=main
VITE_GITHUB_TOKEN=

# Optional error-monitoring collector endpoint (P0.3). When set, captured
# uncaught errors / unhandled rejections are beacon-POSTed here — point it at a
# Sentry tunnel or any custom collector. Left blank, errors still go to the
# browser console and a GA4 `exception` event. See src/lib/errorMonitoring.ts.
VITE_ERROR_ENDPOINT=

# Premium "Listen" view uses Google Cloud Text-to-Speech via the
# `google-cloud-tts` edge function. This is a SERVER secret — set it with
# `supabase secrets set GOOGLE_CLOUD_TTS_API_KEY=...`, NOT as a VITE_ var.
# Free users fall back to the browser's built-in Web Speech API.
